# ============================================================
# ShadowLink — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Database ──
DB_ROOT_PASSWORD=root123
DB_PASSWORD=shadowlink123
DB_DATABASE=shadowlink
DB_USER=shadowlink

# ── Redis ──
REDIS_PASSWORD=

# ── LLM Provider ──
# Point to your local Ollama, vLLM, or cloud API
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Java Backend ──
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=shadowlink-change-this-in-production-at-least-256-bits-long!!
SERVER_PORT=8080

# ── Python AI Service ──
SHADOWLINK_ENV=prod
SHADOWLINK_LOG_LEVEL=INFO
SHADOWLINK_GRPC_PORT=50051

# ── Frontend ──
VITE_API_BASE_URL=/api

# ── Monitoring (optional) ──
GRAFANA_ADMIN_PASSWORD=admin123

# ── Docker Resource Limits ──
JAVA_XMS=256m
JAVA_XMX=1g
AI_WORKERS=2
